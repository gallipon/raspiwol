[mqtt]
host = mqtt.beebotte.com
port = 1883
; Beebotte チャンネルトークン（token_XXXX 形式）
token = token_XXXXXXXXXXXX
; 購読するトピック（コマンド受信）
topic_cmd = CHANNEL/RESOURCE
; 送信するトピック（ログ・ステータス）
topic_log = CHANNEL/log

[update]
; raspiwol.py の GitHub raw URL（"update" コマンドで取得）
; 例: https://raw.githubusercontent.com/USER/raspiwol/main/raspiwol.py
url =

[gpio]
; 電源ボタン用 GPIO ピン番号（BCM 番号、デフォルト 17 = 物理ピン 11）
pwr_pin = 17

[wake]
; 平日朝の自動 Wake（raspiwol-wake.timer → `raspiwol.py wake`）の対象デバイス名
; （raspiwol_devices.csv の名前。未指定なら officepc）
target = officepc

[nightwatch]
; 深夜に PC が起きていたら ntfy.sh へ通知（どちらか空なら無効）
; ntfy.sh のトピック名（https://ntfy.sh/<topic> の <topic> 部分）
ntfy_topic =
; 監視対象 PC の IP アドレス
target_ip = 192.168.1.50

; PC 常駐エージェント（pcsleep_agent.py）のハートビート/生存可視化用リソース "agent" は
; Beebotte コンソールでチャンネルに作成しておくこと（power・autopilot と同様）。
; 未作成の場合 dashboard の Agent 生存表示は「⚫ 不明」になり GPIO ボタンは表示されない。
